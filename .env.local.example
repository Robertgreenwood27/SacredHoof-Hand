# ── Site ───────────────────────────────────────────────────────────────────
# Public base URL of the site. Use http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (auth + database) ───────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Keep this SECRET — server-only. Used by the Stripe webhook to write bookings.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Stripe (payments) ────────────────────────────────────────────────────────
# Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# From `stripe listen` (dev) or the Dashboard webhook endpoint (prod)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
# Must be a verified sender/domain in Resend. resend.dev works for testing.
EMAIL_FROM=Sacred Hoof & Hand <hello@sacredhoofandhand.com>
# Where the practitioner gets new-booking notifications.
PRACTITIONER_EMAIL=her-email@example.com
