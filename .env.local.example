# ── Site ───────────────────────────────────────────────────────────────────
# Public base URL of the site. Use http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (auth + database) ───────────────────────────────────────────────
# Project Settings → API Keys. New projects use the sb_publishable_ / sb_secret_
# keys; the older anon / service_role keys still work as a fallback.
NEXT_PUBLIC_SUPABASE_URL=https://zripokagosbyxrpzzmmt.supabase.co
# Browser/client key — safe to expose publicly (protected by Row Level Security).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_t5Q75JWq7pKAgt7ZZo6z5w_IuSx61ch
# Keep this SECRET — server-only. Used by the Stripe webhook to write bookings.
# NEVER put the real value here — this file is committed. Put it in .env.local.
SUPABASE_SECRET_KEY=sb_secret_xxx

# ── Stripe (payments) ────────────────────────────────────────────────────────
# Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# From `stripe listen` (dev) or the Dashboard webhook endpoint (prod)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
# Must be a verified sender/domain in Resend. resend.dev works for testing.
EMAIL_FROM=Sacred Hoof & Hand <sacredhoofandhand@gmail.com>
# Where the practitioner gets new-booking notifications.
PRACTITIONER_EMAIL=sacredhoofandhand@gmail.com

# ── Dashboard login (single practitioner) ────────────────────────────────────
# Sign in at /login (faint gear in the footer) with PRACTITIONER_EMAIL + this.
# NEVER put the real value here — this file is committed. Put it in .env.local.
DASHBOARD_PASSWORD=choose-a-strong-password
